# ============================================
# HR-RAG Environment Variables
# ============================================

# ===================
# Database (TiDB Cloud)
# ===================
# Use TiDB Cloud for production, local TiDB for development
TIDB_HOST=your-tidb-host.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your-username
TIDB_PASSWORD=your-password
TIDB_DATABASE=hr_rag
DATABASE_URL=mysql+pymysql://${TIDB_USER}:${TIDB_PASSWORD}@${TIDB_HOST}:${TIDB_PORT}/${TIDB_DATABASE}

# Local MySQL (for development without TiDB)
# For local TiDB dev container, root password is typically empty
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=hr_rag
MYSQL_PORT=4000

# ===================
# Redis
# ===================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ===================
# Qdrant Vector DB
# ===================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=your-qdrant-api-key (optional)

# ===================
# Authentication / JWT
# ===================
# ⚠️ CRITICAL: สร้าง secret ใหม่ด้วยคำสั่ง: openssl rand -hex 64
# ไม่ใช้ค่า default ใน production!
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 ชั่วโมง

# Legacy variables (ยังรองรับอยู่)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================
# CORS (Cross-Origin Resource Sharing)
# ===================
# รองรับหลาย domain โดยคั่นด้วย comma เช่น:
# CORS_ORIGINS=https://example.com,http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===================
# AI / LLM Providers
# ===================
# ตั้งค่าเฉพาะ provider ที่ใช้งาน ไม่ต้องใส่ทุกตัว

# OpenAI (GPT-4, GPT-4o, etc.)
# สมัครที่: https://platform.openai.com/
OPENAI_API_KEY=

# Anthropic (Claude)
# สมัครที่: https://www.anthropic.com/
ANTHROPIC_API_KEY=

# Google AI (Gemini)
# สมัครที่: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Kimi (Moonshot AI) - รองรับภาษาไทยดี
# สมัครที่: https://platform.moonshot.cn/
KIMI_API_KEY=

# GLM (Zhipu AI)
# สมัครที่: https://open.bigmodel.cn/
GLM_API_KEY=

# MiniMax
# สมัครที่: https://platform.minimax.chat/
MINIMAX_API_KEY=

# Qwen (Alibaba Cloud)
# สมัครที่: https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# DeepSeek
# สมัครที่: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Custom OpenAI-compatible API
CUSTOM_API_KEY=
CUSTOM_BASE_URL=https://api.openai.com/v1
CUSTOM_MODEL=gpt-4o-mini

# ===================
# Embedding Model
# ===================
OPENAI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ===================
# Ollama (Local Models)
# ===================
# ถ้าใช้ Ollama สำหรับ local inference
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ===================
# Default LLM Provider
# ===================
# เลือก provider หลัก: openai, anthropic, google, ollama, kimi, glm, minimax, qwen, deepseek, custom
DEFAULT_LLM_PROVIDER=openai

# ===================
# Application
# ===================
NODE_ENV=development
LOG_LEVEL=INFO

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# ===================
# File Storage
# ===================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,txt,md,doc,docx

# ===================
# Vector Search
# ===================
VECTOR_COLLECTION_NAME=hr_documents
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===================
# Admin Panel Settings
# ===================
# Session timeout in seconds (86400 = 24 hours)
ADMIN_SESSION_TIMEOUT=86400
# Max failed login attempts before IP block
ADMIN_MAX_LOGIN_ATTEMPTS=5
# IP block duration in seconds (3600 = 1 hour)
ADMIN_IP_BLOCK_DURATION=3600
# How long to keep system logs in days
ADMIN_LOG_RETENTION_DAYS=90
