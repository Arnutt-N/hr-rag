# ============================================
# HR-RAG Environment Variables
# ============================================

# ===================
# Database (TiDB Cloud)
# ===================
# Use TiDB Cloud for production, local TiDB for development
TIDB_HOST=your-tidb-host.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=your-username
TIDB_PASSWORD=your-password
TIDB_DATABASE=hr_rag
DATABASE_URL=mysql+pymysql://${TIDB_USER}:${TIDB_PASSWORD}@${TIDB_HOST}:${TIDB_PORT}/${TIDB_DATABASE}

# Local MySQL (for development without TiDB)
# For local TiDB dev container, root password is typically empty
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=hr_rag
MYSQL_PORT=4000

# ===================
# Redis
# ===================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ===================
# Qdrant Vector DB
# ===================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=your-qdrant-api-key (optional)

# ===================
# Authentication
# ===================
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================
# AI / LLM
# ===================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ===================
# Application
# ===================
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO

# ===================
# Rate Limiting
# ===================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# ===================
# File Storage
# ===================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,txt,md,doc,docx

# ===================
# Vector Search
# ===================
VECTOR_COLLECTION_NAME=hr_documents
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===================
# Admin Panel Settings
# ===================
# Session timeout in seconds (86400 = 24 hours)
ADMIN_SESSION_TIMEOUT=86400
# Max failed login attempts before IP block
ADMIN_MAX_LOGIN_ATTEMPTS=5
# IP block duration in seconds (3600 = 1 hour)
ADMIN_IP_BLOCK_DURATION=3600
# How long to keep system logs in days
ADMIN_LOG_RETENTION_DAYS=90
